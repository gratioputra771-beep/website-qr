// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  GURU
  SISWA
}

enum StatusAbsen {
  HADIR
  SAKIT
  IZIN
  ALFA
  DISPENSASI
}

enum MetodeAbsen {
  QR
  MANUAL
}

enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

// ─────────────────────────────────────────────
// USER (Auth)
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  nama          String
  email         String    @unique
  password      String
  role          Role      @default(SISWA)
  foto          String?
  aktif         Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  guru          Guru?
  siswa         Siswa?
  admin         Admin?

  @@map("users")
}

// ─────────────────────────────────────────────
// GURU
// ─────────────────────────────────────────────

model Guru {
  id        String    @id @default(cuid())
  userId    String    @unique
  nip       String?   @unique
  mapel     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kelas     Kelas[]
  absensi   Absensi[] @relation("GuruInput")

  @@map("guru")
}

// ─────────────────────────────────────────────
// SISWA
// ─────────────────────────────────────────────

model Siswa {
  id           String        @id @default(cuid())
  userId       String        @unique
  nis          String        @unique
  nisn         String?       @unique
  kelasId      String
  jenisKelamin JenisKelamin?
  tanggalLahir DateTime?
  noHpOrtu     String?
  emailOrtu    String?
  alamat       String?
  qrToken      String        @unique @default(cuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  kelas        Kelas         @relation(fields: [kelasId], references: [id])
  absensi      Absensi[]

  @@map("siswa")
}

// ─────────────────────────────────────────────
// ADMIN
// ─────────────────────────────────────────────

model Admin {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin")
}

// ─────────────────────────────────────────────
// KELAS
// ─────────────────────────────────────────────

model Kelas {
  id          String   @id @default(cuid())
  namaKelas   String
  tingkat     Int
  tahunAjaran String
  guruId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guru        Guru     @relation(fields: [guruId], references: [id])
  siswa       Siswa[]
  jadwal      Jadwal[]

  @@unique([namaKelas, tahunAjaran])
  @@map("kelas")
}

// ─────────────────────────────────────────────
// MATA PELAJARAN
// ─────────────────────────────────────────────

model MataPelajaran {
  id        String   @id @default(cuid())
  nama      String
  kode      String   @unique
  createdAt DateTime @default(now())

  jadwal    Jadwal[]
  absensi   Absensi[]

  @@map("mata_pelajaran")
}

// ─────────────────────────────────────────────
// JADWAL PELAJARAN
// ─────────────────────────────────────────────

model Jadwal {
  id              String        @id @default(cuid())
  kelasId         String
  mataPelajaranId String
  hariKe          Int
  jamMulai        String
  jamSelesai      String
  batasWaktuScan  String?

  kelas           Kelas         @relation(fields: [kelasId], references: [id])
  mataPelajaran   MataPelajaran @relation(fields: [mataPelajaranId], references: [id])

  @@map("jadwal")
}

// ─────────────────────────────────────────────
// ABSENSI
// ─────────────────────────────────────────────

model Absensi {
  id              String         @id @default(cuid())
  siswaId         String
  guruId          String?
  mataPelajaranId String?
  tanggal         DateTime       @default(now())
  status          StatusAbsen    @default(HADIR)
  metode          MetodeAbsen    @default(QR)
  keterangan      String?
  suratFoto       String?
  waktuScan       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  siswa           Siswa          @relation(fields: [siswaId], references: [id])
  guru            Guru?          @relation("GuruInput", fields: [guruId], references: [id])
  mataPelajaran   MataPelajaran? @relation(fields: [mataPelajaranId], references: [id])

  @@unique([siswaId, tanggal, mataPelajaranId])
  @@index([tanggal])
  @@index([siswaId, tanggal])
  @@map("absensi")
}

// ─────────────────────────────────────────────
// HARI LIBUR
// ─────────────────────────────────────────────

model HariLibur {
  id         String   @id @default(cuid())
  tanggal    DateTime @unique
  keterangan String
  createdAt  DateTime @default(now())

  @@map("hari_libur")
}
